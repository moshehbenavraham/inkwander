# Newsletter signup endpoint (Buttondown, ConvertKit, Mailchimp, custom worker, etc.).
# Receives POST { "email": string, "source"?: string } as JSON.
# Leave unset to fall back to a prefilled mailto: draft to VITE_CONTACT_EMAIL.
VITE_NEWSLETTER_ENDPOINT=

# Contact form endpoint (Formspree, Netlify Forms, custom worker, etc.).
# Receives POST { "name", "email", "subject", "message" } as JSON.
# Leave unset to fall back to a prefilled mailto: draft to VITE_CONTACT_EMAIL.
VITE_CONTACT_FORM_ENDPOINT=

# Destination address used for mailto: fallbacks and the on-site Contact card.
# Defaults to hello@perspective.blog when unset.
VITE_CONTACT_EMAIL=hello@perspective.blog

# Canonical production URL used for absolute canonical / OG / sitemap links.
# Defaults to https://perspective.blog. Override when deploying under a new
# domain so OG cards, JSON-LD, and the sitemap point at the correct origin.
VITE_SITE_URL=https://perspective.blog

# Optional social profile URLs. Each row in the header/hero/footer is rendered
# only when its env var is set — leave any unused platform empty and the icon
# is omitted. (Previously the hero shipped dead `#instagram` / `#facebook`
# anchors regardless of whether real accounts existed.)
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_FACEBOOK=
VITE_SOCIAL_LINKEDIN=
VITE_SOCIAL_YOUTUBE=

# Optional human-readable contact info for the Contact page. Leave unset and
# the corresponding row simply doesn't render — better than shipping a
# placeholder "+1 (555) 123-4567" number visitors will actually try to dial.
VITE_CONTACT_PHONE=
VITE_CONTACT_LOCATION=
VITE_CONTACT_HOURS=
